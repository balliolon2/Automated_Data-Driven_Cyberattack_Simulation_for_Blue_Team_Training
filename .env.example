# ============================================================
#  SOC Trainer – Environment Variables
#  Copy this file to .env and fill in the values.
#     cp .env.example .env
# ============================================================

# ---------- PostgreSQL ----------
# Connection string used by the Go backend and Python scripts.
# Must match the credentials in docker-compose.yml.
DATABASE_URL=host=localhost user=admin password=password dbname=cyber_sim port=5432 sslmode=disable TimeZone=Asia/Bangkok

# ---------- JWT ----------
# Secret key used to sign and verify JSON Web Tokens.
# Generate one with:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-strong-random-value

# ---------- Go / Gin ----------
# Set to "release" for production, "debug" for development.
GIN_MODE=debug
